      <LineId Id="1026" Count="35" />
      <LineId Id="1063" Count="24" />
      <LineId Id="1163" Count="0" />
      <LineId Id="1088" Count="0" />
      <LineId Id="1164" Count="0" />
      <LineId Id="1089" Count="0" />
      <LineId Id="5" Count="0" />
      <LineId Id="1158" Count="4" />
      <LineId Id="1157" Count="0" />
    </LineIds>
  </POU>
</TcPlcObject>