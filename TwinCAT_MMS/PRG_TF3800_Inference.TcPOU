<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="PRG_TF3800_Inference" Id="{a0c8589b-90e5-42c6-bf74-d1e081e0a917}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM PRG_TF3800_Inference
VAR CONSTANT
    cModelPath  : STRING := 'C:\TwinCAT\3.1\Boot\Plc\Models\cnn_dualbranch.onnx';
    cNClasses   : INT    := 4;
    cInputLen   : UDINT  := 1500;   // 250 bins x 6 channels (flattened)
END_VAR

VAR
    // --- TF3800 inference block ---
    fbInference     : FB_TF3800_ONNX;

    // --- Input tensor ---
    // Shape: [1, 1500] — batch size 1, 1500 features
    aInputTensor    : ARRAY[0..1499] OF LREAL;

    // --- Output tensor ---
    // Shape: [1, 4] — [normal, mass1, mass2, mass3]
    aOutputTensor   : ARRAY[0..3] OF LREAL;

    bModelLoaded    : BOOL   := FALSE;
    bExecute        : BOOL   := FALSE;
    bBusy           : BOOL;
    bDone           : BOOL;
    bError          : BOOL;
    hrError         : HRESULT;

    i               : INT;
    fMaxProb        : LREAL;
    nMaxIdx         : INT;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[// ── 1. Load model ───────────────────────────────────────────
IF NOT bModelLoaded THEN
    fbInference(
        sNetworkPath := cModelPath,
        bLoad        := TRUE,
        bBusy        => bBusy,
        bError       => bError,
        hrErrorCode  => hrError
    );
    IF NOT bBusy AND NOT bError THEN
        bModelLoaded := TRUE;
    END_IF
    RETURN;
END_IF

// ── 2. Buffer ───────────────

IF bDone OR bError THEN
    bExecute := FALSE;
    bDone    := FALSE;
END_IF

FOR i := 0 TO UDINT_TO_INT(cInputLen) - 1 DO
    aInputTensor[i] := PRG_TF3600_Math.aSpectrum[i];
END_FOR

bExecute := TRUE;

// ── 3. Run inference ──────────────────────────────────────────────────────
fbInference(
    sNetworkPath  := cModelPath,
    bLoad         := FALSE,
    bExecute      := bExecute,
    pInput        := ADR(aInputTensor),
    nInputSize    := SIZEOF(aInputTensor),
    pOutput       := ADR(aOutputTensor),
    nOutputSize   := SIZEOF(aOutputTensor),
    bBusy         => bBusy,
    bDone         => bDone,
    bError        => bError,
    hrErrorCode   => hrError
);

IF bDone THEN
    // Find class with highest softmax probability (argmax)
    fMaxProb := -1.0;
    nMaxIdx  := -1;
    FOR i := 0 TO cNClasses - 1 DO
        GVL_CM_Source.aClassProbs[i] := aOutputTensor[i];
        IF aOutputTensor[i] > fMaxProb THEN
            fMaxProb := aOutputTensor[i];
            nMaxIdx  := i;
        END_IF
    END_FOR

    GVL_CM_Source.nPredictedClass := nMaxIdx;
    GVL_CM_Source.fConfidence     := fMaxProb;
    GVL_CM_Source.bFaultDetected  := (nMaxIdx <> 0);  
END_IF]]></ST>
    </Implementation>
    <LineIds Name="PRG_TF3800_Inference">
      <LineId Id="5" Count="0" />
    </LineIds>
  </POU>
</TcPlcObject>
